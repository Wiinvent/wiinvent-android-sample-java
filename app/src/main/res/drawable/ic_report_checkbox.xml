<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- State when the checkbox is checked -->
    <item android:state_checked="true" android:drawable="@drawable/ic_report_checkbox_selected" />

    <!-- State when the checkbox is unchecked -->
    <item android:state_checked="false" android:drawable="@drawable/ic_report_checkbox_unselected" />

    <!-- Default fallback state -->
    <item android:drawable="@drawable/ic_report_checkbox_unselected" />
</selector>